---
import "../styles/global.css";
const { title = "CABEN", description = "Servicios profesionales" } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b1e3a" />
    <link rel="icon" href="/images/logo.png" />
  </head>
  <body class="min-h-screen antialiased">
    <nav class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-[#0b1e3a]/85 backdrop-blur">
      <div class="mx-auto max-w-6xl px-4">
        <div class="flex items-center justify-between py-3">

          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 shrink-0">
            <img src="/images/logo.png" alt="CABEN" class="h-12 w-12 rounded-xl object-contain" />
            <div class="hidden sm:block">
              <p class="text-white font-bold text-lg leading-none">CABEN</p>
              <p class="text-white/50 text-xs">Servicios Marítimos</p>
            </div>
          </a>

          <!-- Nav central -->
          <ul class="hidden md:flex items-center gap-8">
            <li><a class="text-white/80 hover:text-white transition-colors duration-200 font-medium text-sm" href="/">Inicio</a></li>
            <li><a class="text-white/80 hover:text-white transition-colors duration-200 font-medium text-sm" href="/servicios">Servicios</a></li>
            <li><a class="text-white/80 hover:text-white transition-colors duration-200 font-medium text-sm" href="/acerca">Acerca</a></li>
            <li><a class="text-white/80 hover:text-white transition-colors duration-200 font-medium text-sm" href="/contacto">Contacto</a></li>
          </ul>

          <!-- CTA + menú móvil -->
          <div class="flex items-center gap-3">
            <a href="/contacto" class="hidden md:inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-all duration-200 shadow-lg shadow-blue-900/40">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Solicitar Cotización
            </a>

            <!-- Hamburguesa móvil -->
            <details class="md:hidden" id="mobile-menu">
              <summary class="list-none cursor-pointer rounded-lg p-2 text-white/90 hover:bg-white/10">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
              </summary>
              <div class="absolute right-4 top-[68px] w-52 rounded-2xl border border-white/10 bg-[#0b1e3a]/95 backdrop-blur p-2 shadow-2xl">
                <a class="flex items-center rounded-xl px-4 py-3 text-white/90 hover:bg-white/10 text-sm font-medium" href="/">Inicio</a>
                <a class="flex items-center rounded-xl px-4 py-3 text-white/90 hover:bg-white/10 text-sm font-medium" href="/servicios">Servicios</a>
                <a class="flex items-center rounded-xl px-4 py-3 text-white/90 hover:bg-white/10 text-sm font-medium" href="/acerca">Acerca</a>
                <a class="flex items-center rounded-xl px-4 py-3 text-white/90 hover:bg-white/10 text-sm font-medium" href="/contacto">Contacto</a>
                <div class="border-t border-white/10 mt-2 pt-2">
                  <a href="/contacto" class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold px-4 py-3 rounded-xl transition-all">
                    Solicitar Cotización
                  </a>
                </div>
              </div>
            </details>
          </div>
        </div>
      </div>
    </nav>

    <main class="pt-[72px]">
      <slot />
    </main>

    <!-- FOOTER MULTI-COLUMNA -->
    <footer class="border-t border-white/10 bg-black/50 backdrop-blur">
      <div class="mx-auto max-w-6xl px-4 pt-14 pb-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

          <!-- Col 1: Marca + certificaciones -->
          <div>
            <div class="flex items-center gap-3 mb-4">
              <img src="/images/logo.png" alt="CABEN" class="h-12 w-12 rounded-xl object-contain" />
              <div>
                <p class="text-white font-bold text-lg leading-none">CABEN</p>
                <p class="text-white/50 text-xs">Servicios Marítimos</p>
              </div>
            </div>
            <p class="text-white/60 text-sm leading-relaxed mb-5">
              Transporte marítimo profesional en las aguas del sur de Chile. Operamos con los más altos estándares de seguridad.
            </p>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-2">Regulado por</p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-white/5 border border-white/10 text-white/70 text-xs font-medium">
                <svg class="w-3 h-3 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1l2.39 4.843 5.34.776-3.865 3.765.912 5.316L10 13.25 5.223 15.7l.912-5.316L2.27 6.619l5.34-.776L10 1z" clip-rule="evenodd"/></svg>
                DIRECTEMAR
              </span>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-white/5 border border-white/10 text-white/70 text-xs font-medium">
                <svg class="w-3 h-3 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1l2.39 4.843 5.34.776-3.865 3.765.912 5.316L10 13.25 5.223 15.7l.912-5.316L2.27 6.619l5.34-.776L10 1z" clip-rule="evenodd"/></svg>
                Armada de Chile
              </span>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-white/5 border border-white/10 text-white/70 text-xs font-medium">
                <svg class="w-3 h-3 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                SII Reg. Comercio
              </span>
            </div>
          </div>

          <!-- Col 2: Navegación -->
          <div>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-4">Navegación</p>
            <ul class="space-y-2.5">
              {[
                ["Inicio", "/"],
                ["Servicios", "/servicios"],
                ["Acerca de Nosotros", "/acerca"],
                ["Contacto", "/contacto"],
              ].map(([label, href]) => (
                <li>
                  <a href={href} class="text-white/60 hover:text-white text-sm transition-colors flex items-center gap-2">
                    <svg class="w-3 h-3 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Col 3: Contacto -->
          <div>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-4">Contacto</p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-white/60">
                <svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <a href="tel:+56963204644" class="hover:text-white transition-colors">+56 963 204 644</a>
              </li>
              <li class="flex items-start gap-3 text-sm text-white/60">
                <svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <a href="mailto:contacto@caben.cl" class="hover:text-white transition-colors">contacto@caben.cl</a>
              </li>
              <li class="flex items-start gap-3 text-sm text-white/60">
                <svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>Costanera SN, Melinka<br/>Región de Aysén, Chile</span>
              </li>
            </ul>
            <a href="https://wa.me/56963204644" target="_blank" rel="noopener" class="mt-5 inline-flex items-center gap-2 bg-green-600/20 hover:bg-green-600/40 border border-green-500/30 text-green-400 hover:text-green-300 text-xs font-semibold px-4 py-2 rounded-xl transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              WhatsApp Directo
            </a>
          </div>

          <!-- Col 4: Horarios -->
          <div>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-4">Horario de Atención</p>
            <ul class="space-y-2.5 text-sm">
              <li class="flex justify-between text-white/60">
                <span>Nos encontramos siempre activos</span>
          </li>
              <li class="mt-3 flex items-center gap-2 px-3 py-2 rounded-xl bg-green-500/10 border border-green-500/20">
                <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse shrink-0"></span>
                <span class="text-green-400 text-xs font-semibold">Emergencias 24/7</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-white/40 text-xs text-center sm:text-left">
            © {new Date().getFullYear()} CABEN — René Armando Oyarce Cárcamo EIRL. Todos los derechos reservados.
          </p>
          <div class="flex items-center gap-4 text-xs text-white/40">
            <a href="/acerca" class="hover:text-white/70 transition-colors">Política de Privacidad</a>
            <span>·</span>
            <a href="/contacto" class="hover:text-white/70 transition-colors">Términos de Uso</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
