---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSlider from "../components/HeroSlider.astro";

const heroImages = [
  { src: "/images/ini2.jpg", caption: "Servicios Marítimos René Armando Oyarce Cárcamo EIRL" },
  { src: "/images/ini3.jpg", caption: "Transporte de personal y operaciones acuícolas" },
  { src: "/images/ini4.jpg", caption: "Experiencia local en el sur de Chile" },
];

const servicios = [
  {
    img: "/images/servicio1.jpg",
    titulo: "Transporte de Pasajeros",
    desc: "Traslados seguros y puntuales en rutas marítimas locales y regionales del sur de Chile.",
    icon: "🚢",
    features: ["Rutas regulares", "Personal capacitado", "Embarcaciones modernas"],
    href: "/servicios#transporte",
  },
  {
    img: "/images/servicio2.jpg",
    titulo: "Subarriendo de Embarcaciones",
    desc: "Embarcaciones equipadas y con mantención al día para faenas y logística costera.",
    icon: "⚓",
    features: ["Flota moderna", "Mantención incluida", "Contratos flexibles"],
    href: "/servicios#subarriendo",
  },
  {
    img: "/images/servicio3.jpg",
    titulo: "Consultoría Marítima",
    desc: "Optimización de operaciones, cumplimiento normativo y gestión de riesgos marítimos.",
    icon: "💼",
    features: ["Análisis técnico", "Cumplimiento normativo", "Gestión de riesgos"],
    href: "/servicios#consultoria",
  },
];

const destacados = [
  {
    img: "/images/item1.jpg",
    titulo: "Protagonistas del Mar",
    texto: "Impulsamos nuestra compañía mediante el desarrollo de competencias y habilidades de nuestro equipo marítimo."
  },
  {
    img: "/images/item2.jpg",
    titulo: "Calidad al Cliente",
    texto: "Buscamos satisfacer las necesidades de nuestros clientes con servicios innovadores y personalizados."
  },
  {
    img: "/images/item3.jpg",
    titulo: "Nuestro Entorno",
    texto: "Nuestra gente, el mar, lagos y ríos son parte de lo más importante para nosotros y nuestra operación."
  },
];

const estadisticas = [
  { numero: "15+", label: "Años de Experiencia", descripcion: "En operaciones marítimas" },
  { numero: "500+", label: "Clientes Atendidos", descripcion: "Empresas y particulares" },
  { numero: "24/7", label: "Disponibilidad", descripcion: "Atención continua" },
  { numero: "100%", label: "Seguridad", descripcion: "Compromiso total" },
];

const pasos = [
  {
    titulo: "Nos Contactas",
    desc: "Llámanos o escríbenos por WhatsApp. Respondemos en menos de 24 horas hábiles.",
    iconPath: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
  },
  {
    titulo: "Elaboramos Propuesta",
    desc: "Analizamos tu necesidad y preparamos una cotización detallada sin costo ni compromiso.",
    iconPath: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
  {
    titulo: "Acuerdo y Contrato",
    desc: "Revisamos juntos los términos, ajustamos si es necesario y firmamos el acuerdo.",
    iconPath: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    titulo: "Operamos con Seguridad",
    desc: "Ejecutamos el servicio con nuestro equipo certificado y te mantenemos informado.",
    iconPath: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
  },
];

const testimonios = [
  {
    texto: "CABEN ha sido nuestro socio estratégico en transporte marítimo. Su profesionalismo y puntualidad son excepcionales.",
    nombre: "María González",
    cargo: "Gerente de Operaciones",
    empresa: "AquaChile",
    rating: 5
  },
  {
    texto: "La calidad del servicio y la atención al detalle que ofrece el equipo de CABEN superó nuestras expectativas.",
    nombre: "Carlos Mendoza",
    cargo: "Coordinador Logístico",
    empresa: "Salmones Austral",
    rating: 5
  }
];
---
<BaseLayout title="CABEN — Servicios Marítimos" description="Transporte marítimo, subarriendo de embarcaciones y consultoría en el sur de Chile. Experiencia, seguridad y calidad.">

  <!-- HERO SLIDER + CTA overlay -->
  <section class="relative overflow-hidden">
    <HeroSlider images={heroImages} height="h-[85vh] min-h-[560px]" interval={6000} />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0b1e3a]/80 via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute inset-0 flex items-end justify-center pb-20 px-4">
      <div class="text-center max-w-3xl">
        <p class="text-blue-300 text-xs font-semibold uppercase tracking-widest mb-3">Patagonia · Sur de Chile</p>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-5 leading-tight drop-shadow-2xl">
          Transporte Marítimo<br/><span class="text-blue-300">Profesional</span>
        </h1>
        <p class="text-white/75 text-lg mb-8 max-w-xl mx-auto">
          15 años navegando con seguridad y confianza en las aguas del sur de Chile
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contacto" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 shadow-2xl text-base">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Solicitar Cotización Gratis
          </a>
          <a href="/servicios" class="inline-flex items-center justify-center gap-2 border border-white/30 hover:border-white/60 hover:bg-white/10 text-white font-medium px-8 py-4 rounded-xl transition-all duration-200 text-base">
            Ver Servicios
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="border-y border-white/10 bg-black/30 backdrop-blur py-4">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        <span class="text-white/35 text-xs font-semibold uppercase tracking-widest">Avalados por</span>
        <div class="flex items-center gap-2 text-white/55 text-sm font-medium">
          <svg class="w-4 h-4 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1.944l2.387 4.836 5.338.776-3.862 3.764.912 5.315L10 13.944l-4.775 2.691.912-5.315L2.275 7.556l5.338-.776L10 1.944z" clip-rule="evenodd"/></svg>
          DIRECTEMAR
        </div>
        <span class="hidden sm:block text-white/15">|</span>
        <div class="flex items-center gap-2 text-white/55 text-sm font-medium">
          <svg class="w-4 h-4 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1.944l2.387 4.836 5.338.776-3.862 3.764.912 5.315L10 13.944l-4.775 2.691.912-5.315L2.275 7.556l5.338-.776L10 1.944z" clip-rule="evenodd"/></svg>
          Armada de Chile
        </div>
        <span class="hidden sm:block text-white/15">|</span>
        <div class="flex items-center gap-2 text-white/55 text-sm font-medium">
          <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Registro SII
        </div>
        <span class="hidden sm:block text-white/15">|</span>
        <div class="flex items-center gap-2 text-white/55 text-sm font-medium">
          <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Operaciones STCW
        </div>
      </div>
    </div>
  </section>

  <!-- ESTADÍSTICAS -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="text-center mb-12">
      <p class="text-blue-400 text-xs font-semibold uppercase tracking-widest mb-2">TRAYECTORIA</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Líderes en Servicios Marítimos</h2>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">
        Números que reflejan nuestro compromiso con la excelencia y la confianza de nuestros clientes.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {estadisticas.map((stat) => (
        <article class="glass-card p-6 text-center">
          <div class="text-4xl md:text-5xl font-bold text-blue-300 mb-2">{stat.numero}</div>
          <h3 class="text-base font-semibold text-white mb-1">{stat.label}</h3>
          <p class="text-white/50 text-sm">{stat.descripcion}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- POR QUÉ ELEGIRNOS -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="text-center mb-12">
      <p class="text-blue-400 text-xs font-semibold uppercase tracking-widest mb-2">NUESTRA DIFERENCIA</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">¿Por Qué Elegirnos?</h2>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">
        Descubre los valores y principios que nos convierten en el socio ideal para tus operaciones marítimas.
      </p>
    </div>
    <div class="grid gap-8 md:grid-cols-3">
      {destacados.map((d) => (
        <article class="glass-card group overflow-hidden">
          <div class="relative h-56 w-full overflow-hidden">
            <img src={d.img} alt={d.titulo} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-3">{d.titulo}</h3>
            <p class="text-white/70 leading-relaxed text-sm">{d.texto}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- NUESTROS SERVICIOS -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="text-center mb-12">
      <p class="text-blue-400 text-xs font-semibold uppercase tracking-widest mb-2">SERVICIOS</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Nuestros Servicios</h2>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">
        Soluciones integrales para todas tus necesidades marítimas en la Patagonia chilena.
      </p>
    </div>
    <div class="grid gap-8 lg:grid-cols-3">
      {servicios.map((s) => (
        <article class="glass-card group overflow-hidden flex flex-col">
          <div class="relative h-48 w-full overflow-hidden shrink-0">
            <img src={s.img} alt={s.titulo} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <span class="absolute top-4 left-4 text-3xl">{s.icon}</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-white mb-2">{s.titulo}</h3>
            <p class="text-white/70 mb-4 leading-relaxed text-sm flex-1">{s.desc}</p>
            <ul class="space-y-1.5 mb-5">
              {s.features.map((feature) => (
                <li class="flex items-center text-white/60 text-sm gap-2">
                  <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a href={s.href} class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-blue-400/60 hover:bg-blue-600/20 text-white/80 hover:text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-all duration-200">
              Ver más detalles
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/servicios" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3.5 rounded-xl transition-all duration-200 shadow-lg">
        Ver Todos los Servicios
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ¿CÓMO FUNCIONA? -->
  <section class="border-t border-white/10 bg-black/20 py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center mb-14">
        <p class="text-blue-400 text-xs font-semibold uppercase tracking-widest mb-2">PROCESO</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">¿Cómo Funciona?</h2>
        <p class="text-white/60 text-lg max-w-xl mx-auto">
          Comenzar es simple. Cuatro pasos para tener tu servicio marítimo en marcha.
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-0 relative">
        <div class="hidden md:block absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent"></div>

        {pasos.map((paso, i) => (
          <div class="flex flex-col items-center text-center px-6 py-8">
            <div class="relative mb-5">
              <div class="w-20 h-20 rounded-2xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center">
                <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={paso.iconPath} />
                </svg>
              </div>
              <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center shadow-lg">
                {i + 1}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{paso.titulo}</h3>
            <p class="text-white/55 text-sm leading-relaxed">{paso.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/contacto" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3.5 rounded-xl transition-all duration-200 shadow-lg">
          Iniciar Ahora — Es Gratis
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="text-center mb-12">
      <p class="text-blue-400 text-xs font-semibold uppercase tracking-widest mb-2">TESTIMONIOS</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Lo Que Dicen Nuestros Clientes</h2>
    </div>
    <div class="grid gap-8 md:grid-cols-2">
      {testimonios.map((t) => (
        <article class="glass-card p-8">
          <div class="flex gap-1 mb-4">
            {Array.from({length: t.rating}).map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-white/80 leading-relaxed mb-6 italic">"{t.texto}"</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-blue-600/30 border border-blue-500/30 flex items-center justify-center text-blue-300 font-bold text-sm shrink-0">
              {t.nombre.charAt(0)}
            </div>
            <div>
              <p class="text-white font-semibold text-sm">{t.nombre}</p>
              <p class="text-white/50 text-xs">{t.cargo} · {t.empresa}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="border-t border-white/10 bg-gradient-to-br from-blue-900/60 to-[#0b1e3a] py-24">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="text-blue-400 text-xs font-semibold uppercase tracking-widest mb-4">¿LISTO PARA ZARPAR?</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">
        Cotización gratuita<br/>sin compromiso
      </h2>
      <p class="text-white/60 text-lg mb-3 max-w-xl mx-auto">
        Únete a cientos de empresas que confían en nuestros servicios marítimos profesionales.
      </p>
      <div class="flex flex-wrap justify-center gap-5 text-sm text-white/50 mb-10">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Respuesta en 24h
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Cotización gratuita
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Sin compromiso
        </span>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-10 py-4 rounded-xl transition-all duration-200 shadow-2xl text-base">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Solicitar Cotización
