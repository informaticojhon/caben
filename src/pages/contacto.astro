---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactInfo = {
  telefono: "+56 963204644",
  email: "contacto@caben.cl", 
  direccion: "Costanera SN, Melinka, Región de Aysén, Chile"
};
---

<BaseLayout title="CABEN — Contacto" description="Contáctanos para coordinar tu operación marítima. Respuesta rápida y atención personalizada.">
  <!-- Hero Section Mejorado -->
  <section class="relative overflow-hidden py-20">
    <div class="absolute inset-0 -z-10">
      <img
        src="/images/background.jpg"
        alt="Costa de Melinka"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/50 via-blue-800/70 to-blue-900/80"></div>
    </div>
    
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
        Contacta con <span class="text-blue-300">Nosotros</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed mb-12">
        Estamos aquí para hacer realidad tu proyecto marítimo. Respuesta rápida y atención personalizada garantizada.
      </p>
      
      <!-- Estadísticas de respuesta -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="liquid-glass-blue p-6 text-center rounded-2xl floating-animation">
          <div class="text-3xl font-bold text-blue-300 mb-2">24h</div>
          <div class="text-white/80">Tiempo de Respuesta</div>
        </div>
        <div class="liquid-glass-blue p-6 text-center rounded-2xl floating-animation" style="animation-delay: -2s;">
          <div class="text-3xl font-bold text-blue-300 mb-2">100%</div>
          <div class="text-white/80">Respuestas Personalizadas</div>
        </div>
        <div class="liquid-glass-blue p-6 text-center rounded-2xl floating-animation" style="animation-delay: -4s;">
          <div class="text-3xl font-bold text-blue-300 mb-2">15+</div>
          <div class="text-white/80">Años de Experiencia</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Información de Contacto y Mapa -->
  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Información de Contacto -->
      <div class="liquid-glass-blue p-8 floating-animation">
        <h2 class="text-3xl font-bold text-white mb-8 text-center">Información de Contacto</h2>
        <div class="space-y-8">
          <!-- Teléfono -->
          <div class="flex items-start gap-6 group hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-400/30 to-cyan-300/20 flex items-center justify-center flex-shrink-0 group-hover:from-blue-400/40 group-hover:to-cyan-300/30 transition-all duration-300 backdrop-blur-xl border border-white/20 shadow-lg">
              <svg class="w-8 h-8 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-200 transition-colors">Teléfono</h3>
              <a href={`tel:${contactInfo.telefono}`} class="text-lg text-white/90 hover:text-white transition-colors font-medium tracking-wide">
                {contactInfo.telefono}
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-6 group hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-400/30 to-cyan-300/20 flex items-center justify-center flex-shrink-0 group-hover:from-blue-400/40 group-hover:to-cyan-300/30 transition-all duration-300 backdrop-blur-xl border border-white/20 shadow-lg">
              <svg class="w-8 h-8 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-200 transition-colors">Email</h3>
              <a href={`mailto:${contactInfo.email}`} class="text-lg text-white/90 hover:text-white transition-colors font-medium tracking-wide break-all">
                {contactInfo.email}
              </a>
            </div>
          </div>

          <!-- Dirección -->
          <div class="flex items-start gap-6 group hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-400/30 to-cyan-300/20 flex items-center justify-center flex-shrink-0 group-hover:from-blue-400/40 group-hover:to-cyan-300/30 transition-all duration-300 backdrop-blur-xl border border-white/20 shadow-lg">
              <svg class="w-8 h-8 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-200 transition-colors">Dirección</h3>
              <p class="text-lg text-white/90 font-medium leading-relaxed">{contactInfo.direccion}</p>
            </div>
          </div>
        </div>

        <!-- Acciones Rápidas -->
        <div class="mt-10 pt-8 border-t border-white/30">
          <h3 class="text-xl font-bold text-white mb-6 text-center">Contáctanos Directamente</h3>
          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href={`tel:${contactInfo.telefono}`} 
              class="liquid-glass-button flex items-center justify-center gap-3 py-4 px-6 ripple-effect group"
            >
              <svg class="w-6 h-6 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              <span class="font-bold text-lg">Llamar</span>
            </a>
            <a 
              href={`https://wa.me/56963204644?text=Hola%20CABEN,%20quisiera%20consultar%20sobre%20sus%20servicios`}
              target="_blank"
              rel="noopener noreferrer"
              class="liquid-glass-button flex items-center justify-center gap-3 py-4 px-6 ripple-effect group bg-gradient-to-r from-green-500/20 to-emerald-400/20 hover:from-green-500/30 hover:to-emerald-400/30"
            >
              <svg class="w-6 h-6 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.106"/>
              </svg>
              <span class="font-bold text-lg">WhatsApp</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="liquid-glass-blue p-8 floating-animation-delayed">
        <h2 class="text-3xl font-bold text-white mb-8 text-center">Nuestra Ubicación</h2>
        <div class="rounded-2xl overflow-hidden border border-white/20 shadow-2xl hover:shadow-blue-500/20 transition-all duration-500">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d895.9357495568527!2d-73.74363838737617!3d-43.89527873981075!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1ses!2scl!4v1736563618644!5m2!1ses!2scl"
            width="100%" 
            height="450" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full h-[450px] rounded-2xl"
          ></iframe>
        </div>
        <div class="mt-6 p-4 rounded-xl bg-gradient-to-r from-blue-500/10 to-cyan-400/10 border border-white/10 backdrop-blur-md">
          <p class="text-white/90 text-center font-medium text-lg leading-relaxed">
            📍 Nos encontramos en <span class="text-blue-200 font-bold">Melinka</span>, en el corazón de las <span class="text-cyan-200 font-bold">Islas Guaitecas</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action Final -->
  <section class="mx-auto max-w-4xl px-4 pb-24">
    <div class="liquid-glass-blue p-12 floating-animation text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl font-bold text-white mb-6">¿Listo para tu próxima aventura?</h2>
        <p class="text-white/90 text-xl mb-10 leading-relaxed">
          Contacta con nosotros directamente y planifiquemos juntos tu viaje por las hermosas Islas Guaitecas
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
          <a 
            href={`tel:${contactInfo.telefono}`} 
            class="liquid-glass-button flex items-center justify-center gap-4 py-5 px-8 ripple-effect group text-xl font-bold min-w-[200px] hover:scale-105 transition-all duration-300"
          >
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            <span>Llamar Ahora</span>
          </a>
          
          <a 
            href={`https://wa.me/56963204644?text=Hola%20CABEN,%20quisiera%20consultar%20sobre%20sus%20servicios%20de%20transporte%20marítimo.%20¿Podrían%20ayudarme%20con%20información?`}
            target="_blank"
            rel="noopener noreferrer"
            class="liquid-glass-button flex items-center justify-center gap-4 py-5 px-8 ripple-effect group text-xl font-bold min-w-[200px] bg-gradient-to-r from-green-500/20 to-emerald-400/20 hover:from-green-500/30 hover:to-emerald-400/30 hover:scale-105 transition-all duration-300"
          >
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.106"/>
            </svg>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
